<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    用户表 MyBatis Mapper XML 配置文件
    
    对应接口: com.cryptorate.mapper.UserMapper
    对应表: user
    
    @author CryptoRate Team
    @version 2.0
    @since 2026-02-13
-->
<mapper namespace="com.cryptorate.mapper.UserMapper">

    <!-- ========================================
         结果映射
         ======================================== -->
    
    <!-- 用户结果映射 -->
    <resultMap id="BaseResultMap" type="com.cryptorate.entity.User">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="username" property="username" jdbcType="VARCHAR"/>
        <result column="password" property="password" jdbcType="VARCHAR"/>
        <result column="email" property="email" jdbcType="VARCHAR"/>
        <result column="nickname" property="nickname" jdbcType="VARCHAR"/>
        <result column="role" property="role" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="feishu_alert_enabled" property="feishuAlertEnabled" jdbcType="TINYINT"/>
        <result column="feishu_webhook" property="feishuWebhook" jdbcType="VARCHAR"/>
        <result column="daily_briefing_enabled" property="dailyBriefingEnabled" jdbcType="TINYINT"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- ========================================
         SQL 片段
         ======================================== -->
    
    <!-- 基础字段列表 -->
    <sql id="Base_Column_List">
        id, username, password, email, nickname, role, status, feishu_alert_enabled, feishu_webhook, daily_briefing_enabled, created_at, update_time
    </sql>

    <!-- ========================================
         插入操作
         ======================================== -->
    
    <!-- 插入用户 -->
    <insert id="insert" parameterType="com.cryptorate.entity.User" 
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (
            username,
            password,
            email,
            nickname,
            role,
            status,
            feishu_alert_enabled,
            feishu_webhook,
            daily_briefing_enabled,
            created_at
        ) VALUES (
            #{username},
            #{password},
            #{email},
            #{nickname},
            #{role},
            #{status},
            #{feishuAlertEnabled},
            #{feishuWebhook},
            #{dailyBriefingEnabled},
            #{createdAt}
        )
    </insert>

    <!-- 更新用户信息 -->
    <update id="update" parameterType="com.cryptorate.entity.User">
        UPDATE user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="email != null">email = #{email},</if>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="role != null">role = #{role},</if>
            <if test="status != null">status = #{status},</if>
            <if test="feishuAlertEnabled != null">feishu_alert_enabled = #{feishuAlertEnabled},</if>
            <if test="feishuWebhook != null">feishu_webhook = #{feishuWebhook},</if>
            <if test="dailyBriefingEnabled != null">daily_briefing_enabled = #{dailyBriefingEnabled},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 更新个人资料 -->
    <update id="updateProfile" parameterType="com.cryptorate.entity.User">
        UPDATE user
        <set>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="email != null">email = #{email},</if>
            <if test="feishuAlertEnabled != null">feishu_alert_enabled = #{feishuAlertEnabled},</if>
            <if test="feishuWebhook != null">feishu_webhook = #{feishuWebhook},</if>
            <if test="dailyBriefingEnabled != null">daily_briefing_enabled = #{dailyBriefingEnabled},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 仅更新密码字段 -->
    <update id="updatePassword">
        UPDATE user
        SET password = #{password}, update_time = NOW()
        WHERE id = #{id}
    </update>

    <!-- 更新用户状态 -->
    <update id="updateStatus">
        UPDATE user
        SET status = #{status}, update_time = NOW()
        WHERE id = #{id}
    </update>

    <!-- ========================================
         查询操作
         ======================================== -->
    
    <!-- 根据 ID 查询用户 -->
    <select id="selectById" parameterType="java.lang.Long" 
            resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM user
        WHERE id = #{id}
    </select>

    <!-- 根据用户名查询用户 -->
    <select id="selectByUsername" parameterType="java.lang.String" 
            resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM user
        WHERE username = #{username}
    </select>

    <!-- 检查用户名是否存在 -->
    <select id="existsByUsername" parameterType="java.lang.String" 
            resultType="java.lang.Boolean">
        SELECT COUNT(1) > 0
        FROM user
        WHERE username = #{username}
    </select>

    <!-- 管理员：获取所有用户（含搜索） -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM user
        <where>
            <if test="keyword != null and keyword != ''">
                AND (username LIKE CONCAT('%', #{keyword}, '%') OR email LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

    <!-- 获取所有开启了飞书预警的用户 -->
    <select id="selectUsersWithFeishuAlertEnabled" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM user
        WHERE feishu_alert_enabled = 1 AND status = 'ACTIVE'
    </select>

</mapper>
